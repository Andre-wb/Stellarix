<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Runtime theme is driven by Compose; this XML theme is only used by
         the system when the activity window is inflated (splash / insets). -->
    <style name="Theme.Vortex" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
        <item name="android:statusBarColor">@color/launcher_background</item>
        <item name="android:navigationBarColor">@color/launcher_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>

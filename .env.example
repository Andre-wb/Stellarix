# Vortex node config — copy to .env and fill in.
# Secrets (*_SECRET, POSTGRES_PASSWORD, etc.) auto-generate on first run if blank.

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEVICE_NAME=MyNode

# ── Network mode ─────────────────────────────────────────────────────────
# local   — LAN only, no internet
# global  — via Cloudflare Tunnel + obfuscation (most common)
# custom  — pass CONTROLLER_URL/CONTROLLER_PUBKEY yourself
NETWORK_MODE=local

# For global/custom mode only:
CONTROLLER_URL=
CONTROLLER_PUBKEY=
NODE_ANNOUNCE_ENDPOINTS=
CONTROLLER_HEARTBEAT_SEC=60

# ── Storage ──────────────────────────────────────────────────────────────
DB_PATH=vortex.db
UPLOAD_DIR=uploads
KEYS_DIR=keys
MAX_FILE_MB=3072

# ── Identity (set by wizard from 24-word mnemonic) ───────────────────────
NODE_PUBKEY=
WALLET_PUBKEY=
NODE_INITIALIZED=false

# ── On-chain (Vortex Premium + operator rewards) ─────────────────────────
# Program id that holds Config, Subscription, Stake PDAs. Pinned by
# solana_program/deploy.sh — don't edit by hand.
VORTEX_PROGRAM_ID=Vor1exReg1111111111111111111111111111111111

# Solana RPC endpoint. The public mainnet-beta URL aggressively rate-limits
# (HTTP 429) once a node has meaningful traffic — a dedicated RPC is
# strongly recommended in production. Free tiers that work well:
#   - Helius:    https://mainnet.helius-rpc.com/?api-key=<YOUR_KEY>
#   - QuickNode: https://<yours>.solana-mainnet.quiknode.pro/<token>/
#   - Ankr:      https://rpc.ankr.com/solana/<token>
# Leave blank to use the public endpoint (development only).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PREMIUM_CACHE_TTL=300
PREMIUM_RPC_TIMEOUT=4.0

# Treasury wallet (receives register fees + premium revenue). Default is
# the owner of vortexx.sol; override for forks/test deployments.
TREASURY_PUBKEY=5ABkkipTZZEEPNR3cP4MCzftpAhqv6jvM4UTSLPGt5Qq

# Platform-admin dashboard bearer token. Leave empty to disable /admin/*
# entirely (safer default than a guessable default).
ADMIN_TOKEN=

# ── Obfuscation / Stealth (global mode) ──────────────────────────────────
# Disable for testing over Cloudflare Tunnel — the probe detector
# otherwise flags CF edge requests as censorship probes and serves
# them a cover page instead of real content, which Cloudflare then
# returns as 502. Keep enabled in production on real ingress paths.
OBFUSCATION_ENABLED=true

# ── Post-quantum ─────────────────────────────────────────────────────────
# Vortex requires a working post-quantum KEM library (Kyber-768/ML-KEM).
# Install one of:
#   - pip install liboqs-python  (requires native liboqs — "brew install liboqs" first on macOS)
#   - pip install pqcrypto       (pure fallback, no native deps)
# If neither loads, the app starts in SIMULATION MODE — NOT cryptographically
# secure. Set VORTEX_PQ_SIMULATE=1 explicitly to allow it in development.
VORTEX_PQ_SIMULATE=0
VORTEX_PQ_REQUIRED=false
